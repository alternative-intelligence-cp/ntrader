use "exchange.npk".*;
use "crypto.npk".*;
use "events.npk".*;
use "context.npk".*;

extern "libc" {
    func:npk_shim_thread_spawn = int32(void*:start_routine, void*:arg);
    func:sleep = int32(int32:seconds);
    func:puts = int32(string:s);
    func:snprintf = int32(void*:str, int64:size, string:format, string:arg1, string:arg2);
    func:mlock = int32(void*:addr, int64:len);
    func:munlock = int32(void*:addr, int64:len);
}

extern "libnitpick_runtime" {
    func:npk_core_alloc = int64(int64:size);
    func:npk_core_dalloc = void(int64:ptr);
    func:npk_atomic_int32_load = int32(void*:atomic_ptr);
}

pub struct:BinanceClient = {
    int64:api_key_addr;
    int64:signed_secret_addr;
    int32:key_len;
    int32:secret_len;
    LockFreeQueue:events;
};

impl:ExchangeClient:for:BinanceClient = {
    func:auth = NIL(any:client) { pass NIL; };
    
    func:sign_request = string(any:client, string:path, string:data) {
        BinanceClient:bin = cast_unchecked<BinanceClient>(client);
        
        // Binance signature logic: HMAC_SHA256(query_string + body, api_secret).
        int8->:secret = cast_unchecked<int8->>(bin.signed_secret_addr);
        
        int64:concat_data_addr = npk_core_alloc(2048i64);
        int8->:concat_data = cast_unchecked<int8->>(concat_data_addr);
        
        defer {
            drop secure_wipe(concat_data_addr, 2048i64);
            npk_core_dalloc(concat_data_addr);
        }
        
        int32:written = snprintf(cast_unchecked<any->>(concat_data), 2048i64, "%s%s", path, data);
        
        // Generate signature
        string:signed = raw generate_hmac_sha256(secret, bin.secret_len, concat_data, cast_unchecked<int64>(written));
        
        pass signed;
    };
    
    func:submit_order = NIL(any:client, Order:order) { pass NIL; };
    func:cancel_order = NIL(any:client) { pass NIL; };
};

