    // REST POST to /api/v3/userDataStream
    string:path = "/api/v3/userDataStream";
    
    // send POST...
    // parse response...
    string:key = "stub_listen_key";
    pass key;
};

// Scaffold a dedicated background OS thread
pub func:binance_keepalive_thread = any->(any->:arg) {
    WorkerContext->:ctx = cast_unchecked<WorkerContext->>(arg);
    int32:elapsed = 0i32;
    while (true) {
        int32:is_shutdown = npk_atomic_int32_load(cast_unchecked<any->>(ctx->shutdown_flag));
        if (is_shutdown == 1i32) {
            break;
        }
        
        drop sleep(1i32);
        elapsed = elapsed + 1i32;
        
        if (elapsed >= 1800i32) {
            // PUT /api/v3/userDataStream
            elapsed = 0i32;
        }
    }
    pass cast_unchecked<any->>(0i64);
};

pub func:binance_start_keepalive = int32() {
    // Scaffold: npk_shim_thread_spawn requires compiler support for function pointers.
    // int32:tid = npk_shim_thread_spawn(binance_keepalive_thread, cast_unchecked<any->>(0i64));
    pass 0i32;
};

pub func:binance_parse_fast_tick = NIL(BinanceClient:client, wild int8->:buffer, int32:len) {
    // Binance-specific fast-path zero-copy scanner for bookTicker payloads.
    // Handle periodic stream ping/pong frames as required by Binance specifications.
    
    // Binance Timestamping: Normalize Binance's int64 millisecond E and T timestamps to nanoseconds.
    // Ensure the normalization multiplication utilizes explicit prove constraints to guarantee it never exceeds int64 bounds.
    prove(1620000000i64 < 9223372036854i64); // Max ms before ns overflow
    int64:normalized_ts = raw normalize_timestamp_ms(1620000000i64); // dummy ms
    
    // Wire zero-copy output directly to the LockFreeQueue
    LockFreeQueue:local_q = client.events;
    drop queue_push(@local_q, normalized_ts);
    
    pass NIL;
};

pub func:binance_cleanup = NIL() {
    // Implement a failsafe DELETE request to /api/v3/userDataStream during application proc_exit handling
    // to cleanly terminate the session.
    drop puts("Binance: DELETE /api/v3/userDataStream");
    pass NIL;
};

pub func:binance_connect_ws = NIL(BinanceClient:client, string:listen_key) {
    // Connect WebSocket state machine to wss://stream.binance.com:9443
    string:url = "wss://stream.binance.com:9443/stream";
    
    // Construct multiplexed subscription payload for @bookTicker and @depth20@100ms.
    string:sub_payload = "{\"method\":\"SUBSCRIBE\",\"params\":[\"btcusdt@bookTicker\",\"btcusdt@depth20@100ms\",\"stub_listenKey\"],\"id\":1}";
    
    // Incorporate user's private listenKey payload into the stream for @executionReport (fill data).
    pass NIL;
};
