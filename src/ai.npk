pub struct:Macd = {
    Ema:fast_ema;
    Ema:slow_ema;
    Ema:signal_ema;
    #[align(64)]
    simd<tfp64, 8>:histogram;
    int64:ticks;
};

pub func:update_macd_simd = simd<tfp64, 8>(Macd->:macd, simd<tfp64, 8>:prices) {
    if (raw simd_has_err(prices)) {
        // Reset everything
        macd->histogram = raw get_simd_zero();
        macd->ticks = 0i64;
        fail cast_unchecked<tbb32>(1i32);
    }
    
    // Call EMAs
    // STUB
    
    pass raw get_simd_zero();
};

pub struct:Vwap = {
    #[align(64)]
    simd<tfp64, 8>:cumulative_vp;
    #[align(64)]
    simd<tfp64, 8>:cumulative_v;
    int64:ticks;
};

pub func:update_vwap_simd = simd<tfp64, 8>(Vwap->:vwap, simd<tfp64, 8>:prices, simd<tfp64, 8>:volumes) {
    if (raw simd_has_err(prices) || raw simd_has_err(volumes)) {
        vwap->cumulative_vp = raw get_simd_zero();
        vwap->cumulative_v = raw get_simd_zero();
        vwap->ticks = 0i64;
        fail cast_unchecked<tbb32>(1i32);
    }
    
    vwap->cumulative_vp = vwap->cumulative_vp + (prices * volumes);
    vwap->cumulative_v = vwap->cumulative_v + volumes;
    vwap->ticks = vwap->ticks + 1i64;
    
    // STUB division: pass vwap->cumulative_vp / vwap->cumulative_v;
    pass raw get_simd_zero();
};

pub struct:BollingerBands = {
    #[align(64)]
    simd<tfp64, 8>:sma;
    #[align(64)]
    simd<tfp64, 8>:upper_band;
    #[align(64)]
    simd<tfp64, 8>:lower_band;
    int64:period;
    int64:ticks;
};

pub func:update_bb_simd = simd<tfp64, 8>(BollingerBands->:bb, simd<tfp64, 8>:prices) {
    if (raw simd_has_err(prices)) {
        bb->sma = raw get_simd_zero();
        bb->upper_band = raw get_simd_zero();
        bb->lower_band = raw get_simd_zero();
        bb->ticks = 0i64;
        fail cast_unchecked<tbb32>(1i32);
    }
    
    // Calculate SMA and StdDev
    // STUB stddev requires sqrt() which is missing from Nitpick stdlib currently
    pass raw get_simd_zero();
};
